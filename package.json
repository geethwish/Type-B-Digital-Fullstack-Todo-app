{
  "name": "type-b-digital-todo-app",
  "version": "1.0.0",
  "description": "Full-stack TODO application monorepo",
  "private": true,
  "workspaces": [
    "apps/backend",
    "apps/frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=apps/backend\" \"npm run dev --workspace=apps/frontend\"",
    "lint": "npm run lint --workspace=apps/backend && npm run lint --workspace=apps/frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
